{
  "name": "ev-trips-community",
  "version": "1.0.0",
  "private": true,
  "description": "EV Trips Community - A platform for electric vehicle road trip sharing and discovery",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@ev-trips/api",
    "dev:web": "turbo run dev --filter=@ev-trips/web",
    "dev:mobile": "turbo run dev --filter=@ev-trips/mobile",
    "dev:admin": "turbo run dev --filter=@ev-trips/admin",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e",
    "test:cov": "turbo run test:cov",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:turbo": "rm -rf .turbo",
    "db:generate": "turbo run db:generate --filter=@ev-trips/api",
    "db:migrate": "turbo run db:migrate --filter=@ev-trips/api",
    "db:migrate:dev": "turbo run db:migrate:dev --filter=@ev-trips/api",
    "db:seed": "turbo run db:seed --filter=@ev-trips/api",
    "db:studio": "turbo run db:studio --filter=@ev-trips/api",
    "db:reset": "turbo run db:reset --filter=@ev-trips/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "prepare": "husky install",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "turbo": "^2.0.6",
    "typescript": "^5.5.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "pnpm@9.4.0",
  "pnpm": {
    "overrides": {
      "typescript": "^5.5.2"
    }
  }
}
