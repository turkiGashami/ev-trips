# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ev_trips_user
DB_PASSWORD=ev_trips_password
DB_NAME=ev_trips_db
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_MIN=2

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=ev_trips_redis_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_32_char_secret
JWT_REFRESH_SECRET=change_this_refresh_to_another_32_char_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@evtrips.community
EMAIL_FROM_NAME=رحلات EV

# ─── Storage ──────────────────────────────────────────────────────────────────
# local = store in /uploads, s3 = AWS S3 / MinIO
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# S3 / MinIO (only needed if STORAGE_PROVIDER=s3)
S3_BUCKET=ev-trips-media
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_ENDPOINT=                  # leave empty for AWS, set for MinIO e.g. http://localhost:9000
CDN_BASE_URL=                 # optional CloudFront/CDN prefix

# ─── Push Notifications ───────────────────────────────────────────────────────
FCM_SERVER_KEY=               # Firebase Cloud Messaging (optional)
APNS_KEY_ID=                  # Apple Push (optional)
APNS_TEAM_ID=                 # Apple Push (optional)
